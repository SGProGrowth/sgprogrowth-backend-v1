# =============================================================================
# SG Pro Growth LMS — Backend environment variables
# Copy to .env and replace placeholder values. NEVER commit real secrets.
# =============================================================================

# --- Server ---
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
# Comma-separated frontend origins allowed for CORS (required in production)
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5174

# --- Database (matches docker-compose.yml for local dev) ---
DATABASE_URL=postgresql://sgpg:sgpg_dev_password@localhost:5432/sgpg_lms?schema=public

# --- Redis ---
REDIS_URL=redis://localhost:6379

# --- Application secrets ---
# Generate for each environment: openssl rand -base64 48
# Minimum 16 chars in development, 32+ in production (no placeholder values in prod)
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
APP_SECRET=change-me-app-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# --- Object storage (MinIO local / S3 production) ---
STORAGE_PROVIDER=s3
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=sgpg_minio
S3_SECRET_KEY=sgpg_minio_dev_password
S3_BUCKET=sgpg-lms
S3_REGION=us-east-1
S3_USE_SSL=false
S3_SIGNED_URL_TTL_SECONDS=3600
UPLOAD_DIR=uploads

# --- Platform defaults ---
DEFAULT_ORGANIZATION_SLUG=sg-pro-growth
DEFAULT_ORGANIZATION_NAME=SG Pro Growth
APP_URL=http://localhost:5173
APP_NAME=SG Pro Growth
# Public logo URL for HTML emails (defaults to APP_URL/brand/logo.jpeg when unset)
# APP_LOGO_URL=http://localhost:5173/brand/logo.jpeg

# --- Email / SMTP ---
# Option A — individual SMTP credentials (production):
#   SMTP_HOST=smtp.example.com
#   SMTP_PORT=587
#   SMTP_SECURE=false
#   SMTP_USER=noreply@example.com
#   SMTP_PASS=your-mailbox-password
# Option B — connection URL:
#   SMTP_URL=smtps://user:pass@smtp.example.com:465
# Option C — local dev Ethereal test inbox (preview URLs in backend logs):
SMTP_USE_ETHEREAL=true
MAIL_ENABLED=true
MAIL_NOTIFICATIONS_ENABLED=true
MAIL_QUEUE_ENABLED=false
SMTP_HOST=
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=
SMTP_PASS=
SMTP_FROM="SG Pro Growth <noreply@example.com>"
APP_LOGO_URL=

# --- Auth policy ---
REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_EXPIRES_HOURS=24
PASSWORD_RESET_EXPIRES_HOURS=1

# --- Rate limiting (requests per THROTTLE_TTL_MS window; default 60s) ---
THROTTLE_TTL_MS=60000
THROTTLE_DEFAULT_LIMIT=120
THROTTLE_AUTH_LIMIT=20
THROTTLE_USE_REDIS=true
THROTTLE_REGISTER_LIMIT=10
THROTTLE_LOGIN_LIMIT=10
THROTTLE_VERIFY_EMAIL_LIMIT=20
THROTTLE_RESEND_VERIFICATION_LIMIT=5
THROTTLE_FORGOT_PASSWORD_LIMIT=5
THROTTLE_RESET_PASSWORD_LIMIT=10
THROTTLE_REFRESH_LIMIT=30
THROTTLE_LOGOUT_LIMIT=30
THROTTLE_CHANGE_PASSWORD_LIMIT=10
THROTTLE_UPLOAD_LIMIT=30
THROTTLE_CERTIFICATE_VERIFY_LIMIT=30
THROTTLE_PUBLIC_LIMIT=60

# --- Development / E2E (NEVER enable in production) ---
# Enables GET /auth/test/token for verification scripts
E2E_TEST_MODE=false

# --- Logging & background jobs ---
LOG_LEVEL=info
SCHEDULED_JOBS_ENABLED=false
BATCH_IMPORT_QUEUE_ENABLED=false
BATCH_IMPORT_QUEUE_THRESHOLD=50
