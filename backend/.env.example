# Server
NODE_ENV=development
PORT=3000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:5173,http://127.0.0.1:5173,http://127.0.0.1:5174

# Database (matches docker-compose.yml)
DATABASE_URL=postgresql://sgpg:sgpg_dev_password@localhost:5432/sgpg_lms?schema=public

# Redis
REDIS_URL=redis://localhost:6379

# JWT — generate with: openssl rand -base64 64
JWT_ACCESS_SECRET=change-me-access-secret-min-32-chars-long
JWT_REFRESH_SECRET=change-me-refresh-secret-min-32-chars-long
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Object storage (MinIO local)
S3_ENDPOINT=http://localhost:9000
S3_ACCESS_KEY=sgpg_minio
S3_SECRET_KEY=sgpg_minio_dev_password
S3_BUCKET=sgpg-lms
S3_REGION=us-east-1
S3_USE_SSL=false
STORAGE_PROVIDER=s3
S3_SIGNED_URL_TTL_SECONDS=3600
UPLOAD_DIR=uploads

# Platform defaults
DEFAULT_ORGANIZATION_SLUG=sg-pro-growth
DEFAULT_ORGANIZATION_NAME=SG Pro Growth
APP_URL=http://localhost:5173
APP_NAME=SG Pro Growth

# Email / SMTP (use Mailtrap, SendGrid, SES, etc. in production)
MAIL_ENABLED=true
MAIL_NOTIFICATIONS_ENABLED=true
MAIL_QUEUE_ENABLED=false
SMTP_HOST=smtp.mailtrap.io
SMTP_PORT=587
SMTP_SECURE=false
SMTP_USER=your-smtp-user
SMTP_PASS=your-smtp-password
SMTP_FROM="SG Pro Growth <noreply@sgprogrowth.com>"
APP_LOGO_URL=

# Auth policy
REQUIRE_EMAIL_VERIFICATION=true
EMAIL_VERIFICATION_EXPIRES_HOURS=24
PASSWORD_RESET_EXPIRES_HOURS=1

# Rate limiting (requests per minute)
THROTTLE_DEFAULT_LIMIT=120
THROTTLE_AUTH_LIMIT=20

# Production hardening (Phase 3.9)
E2E_TEST_MODE=false
LOG_LEVEL=info
SCHEDULED_JOBS_ENABLED=false
BATCH_IMPORT_QUEUE_ENABLED=false
BATCH_IMPORT_QUEUE_THRESHOLD=50
