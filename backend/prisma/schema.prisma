  quizId           String            @map("quiz_id") @db.Uuid
  enrollmentId     String            @map("enrollment_id") @db.Uuid
  attemptNumber    Int               @map("attempt_number")
  totalScore       Float             @map("total_score") @db.DoublePrecision
  maxScore         Float             @map("max_score") @db.DoublePrecision
  percentage       Float             @db.DoublePrecision
  passed           Boolean
  timeTakenSeconds Int               @map("time_taken_seconds")
  gradingStatus    QuizAttemptStatus @map("grading_status")
  startedAt        DateTime          @map("started_at") @db.Timestamptz
  submittedAt      DateTime          @map("submitted_at") @db.Timestamptz
  createdAt        DateTime          @default(now()) @map("created_at") @db.Timestamptz

  attempt    QuizAttempt @relation(fields: [attemptId], references: [id], onDelete: Cascade)
