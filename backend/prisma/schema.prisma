model Quiz {
  id                    String                    @id @default(uuid()) @db.Uuid
  organizationId        String                    @map("organization_id") @db.Uuid
  instructorId          String                    @map("instructor_id") @db.Uuid
  courseId              String?                   @map("course_id") @db.Uuid
  moduleId              String?                   @map("module_id") @db.Uuid
  lessonId              String?                   @map("lesson_id") @db.Uuid
  title                 String                    @db.VarChar(500)
  description           String?                   @db.Text
  instructions          String?                   @db.Text
  durationMinutes       Int                       @default(30) @map("duration_minutes")
  unlimitedDuration     Boolean                   @default(false) @map("unlimited_duration")
  maxAttempts           Int                       @default(3) @map("max_attempts")
  passScore             Int?                      @map("pass_score")
  totalMarks            Int?                      @map("total_marks")
  isGeneric             Boolean                   @default(false) @map("is_generic")
  randomizeQuestions    Boolean                   @default(false) @map("randomize_questions")
  randomizeOptions      Boolean                   @default(false) @map("randomize_options")
  negativeMarking       Boolean                   @default(false) @map("negative_marking")
  showScoreImmediately  Boolean                   @default(true) @map("show_score_immediately")
  showCorrectAnswers    Boolean                   @default(false) @map("show_correct_answers")
  showExplanations      Boolean                   @default(false) @map("show_explanations")
  availableFrom         DateTime?                 @map("available_from") @db.Timestamptz
  availableUntil        DateTime?                 @map("available_until") @db.Timestamptz
  visibility            QuizVisibility            @default(enrolled)
  selectionMode         QuizQuestionSelectionMode @default(manual) @map("selection_mode")
  selectionRules        Json?                     @map("selection_rules")
  status                QuizStatus                @default(draft)
  createdAt             DateTime                  @default(now()) @map("created_at") @db.Timestamptz
  updatedAt             DateTime                  @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  instructor   User         @relation("QuizInstructor", fields: [instructorId], references: [id])
  course       Course?      @relation(fields: [courseId], references: [id])
  module       CourseModule? @relation(fields: [moduleId], references: [id])
  lesson       CourseLesson? @relation(fields: [lessonId], references: [id])
  questions    QuizQuestion[]
  attempts     QuizAttempt[]
  results      QuizResult[]

  @@index([instructorId, status])
  @@index([courseId, status])
  @@map("quizzes")
}

model QuizQuestion {
  id                 String @id @default(uuid()) @db.Uuid
  quizId             String @map("quiz_id") @db.Uuid
  questionId         String @map("question_bank_item_id") @db.Uuid
  pinnedVersion      Int?   @map("pinned_version")
