generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─── Enums ───────────────────────────────────────────────────────────────────

enum UserStatus {
  active
  suspended
  pending
}

enum UserRole {
  student
  instructor
  org_admin
  platform_admin
}

enum OrgMemberRole {
  member
  admin
}

enum OrganizationStatus {
  active
  suspended
}

enum CourseVisibility {
  public
  private
  invite
}

enum CourseStatus {
  draft
  published
  archived
}

enum LessonType {
  video
  pdf
  resource
  live
  quiz
  assignment
}

enum EnrollmentStatus {
  active
  completed
  withdrawn
}

enum BatchStatus {
  draft
  upcoming
  active
  completed
  cancelled
  archived
}

enum BatchVisibility {
  public
  private
  invite
}

enum BatchInstructorRole {
  lead
  assistant
}

enum BatchEnrollmentStatus {
  active
  waitlist
  completed
  dropped
}

enum BatchImportJobStatus {
  pending
  preview
  processing
  completed
  failed
  rolled_back
}

enum BatchImportRowStatus {
  valid
  warning
  error
  imported
  skipped
}

enum AssignmentStatus {
  draft
  published
  closed
}

enum SubmissionStatus {
  pending
  submitted
  graded
  late
  returned
}

enum AssignmentVisibility {
  enrolled
  hidden
}

enum QuizStatus {
  draft
  published
  archived
}

enum QuizVisibility {
  enrolled
  hidden
  public
}

enum QuizAttemptStatus {
  in_progress
  submitted
  auto_graded
  pending_manual
  graded
  expired
}

enum QuizAnswerGradingStatus {
  ungraded
  auto_graded
  pending_manual
  manually_graded
}

enum QuizQuestionSelectionMode {
  manual
  category
  tag
  difficulty
  random
}

enum QuestionType {
  multiple_choice
  multiple_choice_multi
  true_false
  short_answer
  essay
  long_answer
  fill_blank
  matching
  ordering
}

enum QuestionDifficulty {
  easy
  medium
  hard
}

enum QuestionStatus {
  active
  archived
}

enum NotificationType {
  assignment
  quiz
  coaching
  announcement
  grade
  enrollment
  system
  message
  progress
  certificate
  batch
}

enum CertificateStatus {
  active
  revoked
  expired
  superseded
}

enum CertificateVerificationResult {
  valid
  invalid
  revoked
  expired
}

enum LessonProgressStatus {
  not_started
  in_progress
  completed
}

enum LearningActivityType {
  lesson_started
  lesson_completed
  lesson_incomplete
  video_progress
  resource_download
  assignment_submitted
  quiz_submitted
  quiz_passed
  module_completed
  course_completed
  live_attended
}

enum CoachingSessionStatus {
  scheduled
  completed
  cancelled
}

enum AnnouncementAudience {
  all
  course
  at_risk
}

enum AnnouncementStatus {
  draft
  sent
}

enum MediaAssetType {
  avatar
  course_thumbnail
  course_banner
  batch_thumbnail
  batch_banner
  lesson_resource
  assignment_attachment
  submission_file
  certificate_pdf
  image
  document
  archive
  other
}

enum MediaVisibility {
  public
  private
}

// ─── Identity & auth ─────────────────────────────────────────────────────────

model User {
  id              String     @id @default(uuid()) @db.Uuid
  email           String     @unique @db.VarChar(320)
  passwordHash    String     @map("password_hash") @db.VarChar(255)
  status          UserStatus @default(active)
  emailVerifiedAt DateTime?  @map("email_verified_at") @db.Timestamptz
  lastLoginAt     DateTime?  @map("last_login_at") @db.Timestamptz
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  roles               UserRoleAssignment[]
  refreshTokens       RefreshToken[]
  emailVerificationTokens EmailVerificationToken[]
  passwordResetTokens PasswordResetToken[]
  organizationMembers OrganizationMember[]
  studentProfile      StudentProfile?
  instructorProfile   InstructorProfile?
  instructedCourses   Course[]             @relation("CourseInstructor")
  enrollments         Enrollment[]
  notifications       Notification[]
  sentMessages        Message[]            @relation("MessageSender")
  threadParticipants  ThreadParticipant[]
  calendarEvents      CalendarEvent[]
  coachingSessions    CoachingSession[]    @relation("CoachingInstructor")
  questions           Question[]
  createdQuestions    Question[]           @relation("QuestionCreatedBy")
  updatedQuestions    Question[]           @relation("QuestionUpdatedBy")
  questionVersions    QuestionVersion[]    @relation("QuestionVersionAuthor")
  questionCategories  QuestionCategory[]
  assignments         Assignment[]         @relation("AssignmentInstructor")
  gradedSubmissions   AssignmentSubmission[] @relation("SubmissionGrader")
  assignmentGrades    AssignmentGrade[]    @relation("AssignmentGradeGrader")
  quizzes             Quiz[]               @relation("QuizInstructor")
  announcements       Announcement[]
  learningActivities    LearningActivity[]
  studentCertificates   Certificate[]        @relation("StudentCertificates")
  revokedCertificates   Certificate[]        @relation("RevokedCertificates")
  issuedCertificates    Certificate[]        @relation("IssuedCertificates")
  batchInstructorRoles  BatchInstructor[]
  batchImportJobs       BatchImportJob[]
  batchEnrollments      BatchEnrollment[]
  mediaAssets           MediaAsset[]

  @@map("users")
}

model UserRoleAssignment {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @map("user_id") @db.Uuid
  role      UserRole
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, role])
  @@index([userId])
  @@map("user_roles")
}

model RefreshToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  revokedAt DateTime? @map("revoked_at") @db.Timestamptz
  userAgent String?   @map("user_agent") @db.VarChar(512)
  ipAddress String?   @map("ip_address") @db.VarChar(45)
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("refresh_tokens")
}

model EmailVerificationToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("email_verification_tokens")
}

model PasswordResetToken {
  id        String    @id @default(uuid()) @db.Uuid
  userId    String    @map("user_id") @db.Uuid
  tokenHash String    @map("token_hash") @db.VarChar(255)
  expiresAt DateTime  @map("expires_at") @db.Timestamptz
  usedAt    DateTime? @map("used_at") @db.Timestamptz
  createdAt DateTime  @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@map("password_reset_tokens")
}

// ─── Organizations ─────────────────────────────────────────────────────────────

model Organization {
  id        String             @id @default(uuid()) @db.Uuid
  name      String             @db.VarChar(255)
  slug      String             @unique @db.VarChar(100)
  logoUrl   String?            @map("logo_url") @db.VarChar(512)
  settings  Json               @default("{}")
  status    OrganizationStatus @default(active)
  createdAt DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  members      OrganizationMember[]
  courses      Course[]
  batches      Batch[]
  enrollments  Enrollment[]
  assignments  Assignment[]
  quizzes      Quiz[]
  questionBank Question[]
  questionCategories QuestionCategory[]
  questionTags QuestionTag[]
  announcements Announcement[]
  certificateTemplates CertificateTemplate[]
  certificates Certificate[]
  batchImportJobs BatchImportJob[]
  mediaAssets     MediaAsset[]

  @@map("organizations")
}

model OrganizationMember {
  id             String        @id @default(uuid()) @db.Uuid
  organizationId String      @map("organization_id") @db.Uuid
  userId         String        @map("user_id") @db.Uuid
  role           OrgMemberRole @default(member)
  joinedAt       DateTime      @default(now()) @map("joined_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User         @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, userId])
  @@index([userId])
  @@map("organization_members")
}

// ─── Profiles ─────────────────────────────────────────────────────────────────

model StudentProfile {
  userId            String   @id @map("user_id") @db.Uuid
  displayName       String   @map("display_name") @db.VarChar(255)
  phone             String?  @db.VarChar(30)
  title             String?  @db.VarChar(255)
  bio               String?  @db.Text
  avatarUrl         String?  @map("avatar_url") @db.VarChar(512)
  organizationLabel String?  @map("organization_label") @db.VarChar(255)
  timezone          String   @default("Asia/Kolkata") @db.VarChar(64)
  preferences       Json     @default("{}")
  createdAt         DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("student_profiles")
}

model InstructorProfile {
  userId       String   @id @map("user_id") @db.Uuid
  displayName  String   @map("display_name") @db.VarChar(255)
  phone        String?  @db.VarChar(30)
  designation  String?  @db.VarChar(255)
  title        String?  @db.VarChar(255)
  bio          String?  @db.Text
  experience   String?  @db.Text
  publicSlug   String?  @unique @map("public_slug") @db.VarChar(100)
  avatarUrl    String?  @map("avatar_url") @db.VarChar(512)
  organizationLabel String? @map("organization_label") @db.VarChar(255)
  expertise    String[] @default([])
  credentials  String[] @default([])
  skills       String[] @default([])
  avgRating    Float    @default(0) @map("avg_rating")
  payoutDetails Json    @default("{}") @map("payout_details")
  createdAt    DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt    DateTime @updatedAt @map("updated_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@map("instructor_profiles")
}

// ─── Courses & curriculum ─────────────────────────────────────────────────────

model Category {
  id          String   @id @default(uuid()) @db.Uuid
  slug        String   @unique @db.VarChar(100)
  title       String   @db.VarChar(255)
  description String?  @db.Text
  icon        String?  @db.VarChar(64)
  createdAt   DateTime @default(now()) @map("created_at") @db.Timestamptz

  courses Course[]

  @@map("categories")
}

model Course {
  id               String           @id @default(uuid()) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  instructorId     String           @map("instructor_id") @db.Uuid
  categoryId       String?          @map("category_id") @db.Uuid
  slug             String           @db.VarChar(150)
  title            String           @db.VarChar(500)
  subtitle         String?          @db.VarChar(500)
  description      String?          @db.Text
  level            String?          @db.VarChar(50)
  durationHours    Int?             @map("duration_hours")
  priceCents       Int              @default(0) @map("price_cents")
  currency         String           @default("INR") @db.VarChar(3)
  visibility       CourseVisibility @default(public)
  status           CourseStatus     @default(draft)
  coachingIncluded Boolean          @default(false) @map("coaching_included")
  thumbnailUrl     String?          @map("thumbnail_url") @db.VarChar(512)
  bannerUrl        String?          @map("banner_url") @db.VarChar(512)
  ratingAvg        Float            @default(0) @map("rating_avg")
  reviewCount      Int              @default(0) @map("review_count")
  featured         Boolean          @default(false)
  trending         Boolean          @default(false)
  isNew            Boolean          @default(false) @map("is_new")
  forTeams         Boolean          @default(false) @map("for_teams")
  publishedAt      DateTime?        @map("published_at") @db.Timestamptz
  createdAt        DateTime         @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime         @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization    @relation(fields: [organizationId], references: [id])
  instructor   User            @relation("CourseInstructor", fields: [instructorId], references: [id])
  category     Category?       @relation(fields: [categoryId], references: [id])
  outcomes     CourseOutcome[]
  requirements CourseRequirement[]
  modules      CourseModule[]
  batches      Batch[]
  enrollments  Enrollment[]
  assignments  Assignment[]
  quizzes      Quiz[]
  questions    Question[]
  announcements Announcement[]
  lessonProgress LessonProgress[]
  moduleProgress ModuleProgress[]
  courseProgress CourseProgress[]
  learningActivities LearningActivity[]
  certificates       Certificate[]
  certificateRule    CertificateCompletionRule?
  batchImportJobs    BatchImportJob[]
  mediaAssets        MediaAsset[]

  @@unique([organizationId, slug])
  @@index([instructorId, status])
  @@index([organizationId, status, publishedAt])
  @@index([organizationId, status, visibility, featured])
  @@index([categoryId, status])
  @@map("courses")
}

model CourseOutcome {
  id        String @id @default(uuid()) @db.Uuid
  courseId  String @map("course_id") @db.Uuid
  text      String @db.Text
  sortOrder Int    @default(0) @map("sort_order")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_outcomes")
}

model CourseRequirement {
  id        String @id @default(uuid()) @db.Uuid
  courseId  String @map("course_id") @db.Uuid
  text      String @db.Text
  sortOrder Int    @default(0) @map("sort_order")

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("course_requirements")
}

model CourseModule {
  id        String   @id @default(uuid()) @db.Uuid
  courseId  String   @map("course_id") @db.Uuid
  title     String   @db.VarChar(500)
  sortOrder Int      @default(0) @map("sort_order")
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  course  Course         @relation(fields: [courseId], references: [id], onDelete: Cascade)
  lessons CourseLesson[]
  assignments Assignment[]
  questions Question[]
  quizzes Quiz[]
  lessonProgress LessonProgress[]
  moduleProgress ModuleProgress[]

  @@index([courseId])
  @@map("course_modules")
}

model CourseLesson {
  id              String     @id @default(uuid()) @db.Uuid
  moduleId        String     @map("module_id") @db.Uuid
  title           String     @db.VarChar(500)
  description     String?    @db.Text
  type            LessonType
  durationMinutes Int?       @map("duration_minutes")
  sortOrder       Int        @default(0) @map("sort_order")
  content         Json       @default("{}")
  createdAt       DateTime   @default(now()) @map("created_at") @db.Timestamptz
  updatedAt       DateTime   @updatedAt @map("updated_at") @db.Timestamptz

  module CourseModule  @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  assets LessonAsset[]
  assignments Assignment[]
  questions Question[]
  quizzes Quiz[]
  lessonProgress LessonProgress[]
  enrollmentLastLesson Enrollment[] @relation("EnrollmentLastLesson")
  courseProgressLastLesson CourseProgress[] @relation("CourseProgressLastLesson")
  learningActivities LearningActivity[]
  mediaAssets MediaAsset[]

  @@index([moduleId])
  @@map("course_lessons")
}

model LessonAsset {
  id              String   @id @default(uuid()) @db.Uuid
  lessonId        String   @map("lesson_id") @db.Uuid
  assetType       String   @map("asset_type") @db.VarChar(50)
  storageKey      String   @map("storage_key") @db.VarChar(512)
  mimeType        String   @map("mime_type") @db.VarChar(128)
  sizeBytes       Int      @map("size_bytes")
  durationSeconds Int?     @map("duration_seconds")
  createdAt       DateTime @default(now()) @map("created_at") @db.Timestamptz

  lesson CourseLesson @relation(fields: [lessonId], references: [id], onDelete: Cascade)

  @@map("lesson_assets")
}

// ─── Enrollments & batches ────────────────────────────────────────────────────

model Batch {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  courseId       String          @map("course_id") @db.Uuid
  instructorId   String          @map("instructor_id") @db.Uuid
  batchCode      String          @map("batch_code") @db.VarChar(50)
  name           String          @db.VarChar(255)
  description    String?         @db.Text
  startDate      DateTime        @map("start_date") @db.Date
  endDate        DateTime?       @map("end_date") @db.Date
  schedule       String?         @db.VarChar(255)
  maxCapacity    Int             @default(30) @map("max_capacity")
  status         BatchStatus     @default(draft)
  visibility     BatchVisibility @default(private)
  published      Boolean         @default(false)
  thumbnailUrl   String?         @map("thumbnail_url") @db.VarChar(512)
  bannerUrl      String?         @map("banner_url") @db.VarChar(512)
  completionRate Float           @default(0) @map("completion_rate")
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  organization    Organization      @relation(fields: [organizationId], references: [id])
  course          Course            @relation(fields: [courseId], references: [id])
  instructors     BatchInstructor[]
  batchEnrollments BatchEnrollment[]
  enrollments     Enrollment[]
  events          BatchEvent[]
  importJobs      BatchImportJob[]
  mediaAssets     MediaAsset[]

  @@unique([organizationId, batchCode])
  @@index([courseId, status])
  @@index([organizationId, published])
  @@map("batches")
}

model BatchInstructor {
  id           String              @id @default(uuid()) @db.Uuid
  batchId      String              @map("batch_id") @db.Uuid
  instructorId String              @map("instructor_id") @db.Uuid
  role         BatchInstructorRole @default(assistant)
  permissions  Json                @default("{}")
  createdAt    DateTime            @default(now()) @map("created_at") @db.Timestamptz

  batch      Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)
  instructor User  @relation(fields: [instructorId], references: [id], onDelete: Cascade)

  @@unique([batchId, instructorId])
  @@index([instructorId])
  @@map("batch_instructors")
}

model BatchEnrollment {
  id           String                @id @default(uuid()) @db.Uuid
  batchId      String                @map("batch_id") @db.Uuid
  studentId    String                @map("student_id") @db.Uuid
  enrollmentId String?               @map("enrollment_id") @db.Uuid
  status       BatchEnrollmentStatus @default(active)
  enrolledAt   DateTime              @default(now()) @map("enrolled_at") @db.Timestamptz
  droppedAt    DateTime?             @map("dropped_at") @db.Timestamptz
  notes        String?               @db.Text

  batch      Batch       @relation(fields: [batchId], references: [id], onDelete: Cascade)
  student    User        @relation(fields: [studentId], references: [id], onDelete: Cascade)
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id], onDelete: SetNull)

  @@unique([batchId, studentId])
  @@index([batchId, status])
  @@index([studentId])
  @@map("batch_enrollments")
}

model BatchEvent {
  id             String   @id @default(uuid()) @db.Uuid
  batchId        String   @map("batch_id") @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  title          String   @db.VarChar(500)
  description    String?  @db.Text
  type           String   @db.VarChar(50)
  startsAt       DateTime @map("starts_at") @db.Timestamptz
  endsAt         DateTime? @map("ends_at") @db.Timestamptz
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  batch Batch @relation(fields: [batchId], references: [id], onDelete: Cascade)

  @@index([batchId, startsAt])
  @@map("batch_events")
}

model BatchImportJob {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  instructorId   String               @map("instructor_id") @db.Uuid
  batchId        String?              @map("batch_id") @db.Uuid
  courseId       String?              @map("course_id") @db.Uuid
  fileName       String               @map("file_name") @db.VarChar(255)
  status         BatchImportJobStatus @default(pending)
  totalRows      Int                  @default(0) @map("total_rows")
  successCount   Int                  @default(0) @map("success_count")
  failureCount   Int                  @default(0) @map("failure_count")
  warningCount   Int                  @default(0) @map("warning_count")
  columnMapping  Json                 @default("{}") @map("column_mapping")
  summary        Json                 @default("{}")
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz
  completedAt    DateTime?            @map("completed_at") @db.Timestamptz

  organization Organization    @relation(fields: [organizationId], references: [id])
  instructor   User            @relation(fields: [instructorId], references: [id])
  batch        Batch?          @relation(fields: [batchId], references: [id], onDelete: SetNull)
  course       Course?         @relation(fields: [courseId], references: [id], onDelete: SetNull)
  rows         BatchImportRow[]

  @@index([instructorId, createdAt])
  @@map("batch_import_jobs")
}

model BatchImportRow {
  id           String               @id @default(uuid()) @db.Uuid
  jobId        String               @map("job_id") @db.Uuid
  rowNumber    Int                  @map("row_number")
  rawData      Json                 @default("{}") @map("raw_data")
  parsedData   Json                 @default("{}") @map("parsed_data")
  status       BatchImportRowStatus @default(valid)
  message      String?              @db.Text
  studentId    String?              @map("student_id") @db.Uuid
  enrollmentId String?              @map("enrollment_id") @db.Uuid

  job BatchImportJob @relation(fields: [jobId], references: [id], onDelete: Cascade)

  @@index([jobId, status])
  @@map("batch_import_rows")
}

model Enrollment {
  id               String           @id @default(uuid()) @db.Uuid
  organizationId   String           @map("organization_id") @db.Uuid
  studentId        String           @map("student_id") @db.Uuid
  courseId         String           @map("course_id") @db.Uuid
  batchId          String?          @map("batch_id") @db.Uuid
  status           EnrollmentStatus @default(active)
  progressPct      Int              @default(0) @map("progress_pct")
  modulesCompleted Int              @default(0) @map("modules_completed")
  hoursSpent       Float            @default(0) @map("hours_spent")
  lastLessonId     String?          @map("last_lesson_id") @db.Uuid
  enrolledAt       DateTime         @default(now()) @map("enrolled_at") @db.Timestamptz
  completedAt      DateTime?        @map("completed_at") @db.Timestamptz
  lastAccessedAt   DateTime?        @map("last_accessed_at") @db.Timestamptz

  organization Organization           @relation(fields: [organizationId], references: [id])
  student      User                   @relation(fields: [studentId], references: [id])
  course       Course                 @relation(fields: [courseId], references: [id])
  batch        Batch?                 @relation(fields: [batchId], references: [id])
  lastLesson   CourseLesson?          @relation("EnrollmentLastLesson", fields: [lastLessonId], references: [id], onDelete: SetNull)
  submissions  AssignmentSubmission[]
  quizAttempts QuizAttempt[]
  quizResults  QuizResult[]
  certificates Certificate[]
