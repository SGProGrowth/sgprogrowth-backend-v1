  maxScore     Int      @map("max_score")
  feedback     String?  @db.Text
  returned     Boolean  @default(false)
  gradedAt     DateTime @default(now()) @map("graded_at") @db.Timestamptz

  submission AssignmentSubmission @relation(fields: [submissionId], references: [id], onDelete: Cascade)
  grader     User                 @relation("AssignmentGradeGrader", fields: [graderId], references: [id])

  @@index([submissionId, gradedAt])
  @@map("assignment_grades")
}

// ─── Communications ───────────────────────────────────────────────────────────

model Announcement {
  id             String               @id @default(uuid()) @db.Uuid
  organizationId String               @map("organization_id") @db.Uuid
  instructorId   String               @map("instructor_id") @db.Uuid
  courseId       String?              @map("course_id") @db.Uuid
  title          String               @db.VarChar(500)
  body           String               @db.Text
  audience       AnnouncementAudience @default(all)
  status         AnnouncementStatus   @default(draft)
  publishedAt    DateTime?            @map("published_at") @db.Timestamptz
  createdAt      DateTime             @default(now()) @map("created_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  instructor   User         @relation(fields: [instructorId], references: [id])
  course       Course?      @relation(fields: [courseId], references: [id])

  @@map("announcements")
}

model MessageThread {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  subject        String   @db.VarChar(500)
  courseId       String?  @map("course_id") @db.Uuid
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  messages     Message[]
  participants ThreadParticipant[]

  @@map("message_threads")
}

model ThreadParticipant {
  id       String @id @default(uuid()) @db.Uuid
  threadId String @map("thread_id") @db.Uuid
  userId   String @map("user_id") @db.Uuid

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  user   User          @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([threadId, userId])
  @@map("thread_participants")
}

model Message {
  id        String    @id @default(uuid()) @db.Uuid
  threadId  String    @map("thread_id") @db.Uuid
  senderId  String    @map("sender_id") @db.Uuid
  body      String    @db.Text
  sentAt    DateTime  @default(now()) @map("sent_at") @db.Timestamptz
  readAt    DateTime? @map("read_at") @db.Timestamptz

  thread MessageThread @relation(fields: [threadId], references: [id], onDelete: Cascade)
  sender User          @relation("MessageSender", fields: [senderId], references: [id])

  @@index([threadId, sentAt])
  @@map("messages")
}

model Notification {
  id             String           @id @default(uuid()) @db.Uuid
  userId         String           @map("user_id") @db.Uuid
  organizationId String?          @map("organization_id") @db.Uuid
  type           NotificationType
  title          String           @db.VarChar(500)
  body           String           @db.Text
  actionUrl      String?          @map("action_url") @db.VarChar(512)
  metadata       Json             @default("{}")
  readAt         DateTime?        @map("read_at") @db.Timestamptz
  createdAt      DateTime         @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@map("notifications")
}

// ─── Calendar & coaching ──────────────────────────────────────────────────────

model CalendarEvent {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  userId         String   @map("user_id") @db.Uuid
  title          String   @db.VarChar(500)
  startsAt       DateTime @map("starts_at") @db.Timestamptz
  endsAt         DateTime @map("ends_at") @db.Timestamptz
  type           String   @db.VarChar(50)
  courseId       String?  @map("course_id") @db.Uuid
  location       String?  @db.VarChar(255)
  metadata       Json     @default("{}")
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, startsAt])
  @@map("calendar_events")
}

model CoachingSession {
  id              String                @id @default(uuid()) @db.Uuid
  organizationId  String                @map("organization_id") @db.Uuid
  instructorId    String                @map("instructor_id") @db.Uuid
  enrollmentId    String?               @map("enrollment_id") @db.Uuid
  title           String                @db.VarChar(500)
  startsAt        DateTime              @map("starts_at") @db.Timestamptz
  durationMinutes Int                   @map("duration_minutes")
  type            String                @db.VarChar(50)
  status          CoachingSessionStatus @default(scheduled)
  meetingUrl      String?               @map("meeting_url") @db.VarChar(512)
  notes           String?               @db.Text
  createdAt       DateTime              @default(now()) @map("created_at") @db.Timestamptz

  instructor User        @relation("CoachingInstructor", fields: [instructorId], references: [id])
  enrollment Enrollment? @relation(fields: [enrollmentId], references: [id])

  @@index([instructorId, startsAt])
  @@map("coaching_sessions")
}

// ─── Certificates & leads ─────────────────────────────────────────────────────

model CertificateTemplate {
  id             String   @id @default(uuid()) @db.Uuid
  organizationId String   @map("organization_id") @db.Uuid
  name           String   @db.VarChar(255)
  slug           String   @db.VarChar(100)
  description    String?  @db.Text
  isDefault      Boolean  @default(false) @map("is_default")
  design         Json     @default("{}")
  active         Boolean  @default(true)
  createdAt      DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  certificates Certificate[]

  @@unique([organizationId, slug])
  @@index([organizationId, active])
  @@map("certificate_templates")
}

model CertificateCompletionRule {
  id                          String   @id @default(uuid()) @db.Uuid
  courseId                    String   @unique @map("course_id") @db.Uuid
  requireProgressPct          Int      @default(100) @map("require_progress_pct")
  requireAllLessons           Boolean  @default(true) @map("require_all_lessons")
  requireAssignmentsSubmitted Boolean  @default(false) @map("require_assignments_submitted")
  minAssignmentScorePct       Int?     @map("min_assignment_score_pct")
  requireQuizPass             Boolean  @default(false) @map("require_quiz_pass")
  minQuizPassPct              Int      @default(70) @map("min_quiz_pass_pct")
  requireLiveSessions         Boolean  @default(false) @map("require_live_sessions")
  createdAt                   DateTime @default(now()) @map("created_at") @db.Timestamptz
  updatedAt                   DateTime @updatedAt @map("updated_at") @db.Timestamptz

  course Course @relation(fields: [courseId], references: [id], onDelete: Cascade)

  @@map("certificate_completion_rules")
}

model Certificate {
  id                String            @id @default(uuid()) @db.Uuid
  organizationId    String            @map("organization_id") @db.Uuid
  enrollmentId      String            @map("enrollment_id") @db.Uuid
  courseId          String            @map("course_id") @db.Uuid
  studentId         String            @map("student_id") @db.Uuid
  templateId        String?           @map("template_id") @db.Uuid
  credentialId      String            @unique @map("credential_id") @db.VarChar(100)
  certificateNumber String            @unique @map("certificate_number") @db.VarChar(100)
  title             String            @db.VarChar(500)
  studentName       String            @map("student_name") @db.VarChar(255)
  instructorName    String            @map("instructor_name") @db.VarChar(255)
  skills            String[]          @default([])
  status            CertificateStatus @default(active)
  completionDate    DateTime          @map("completion_date") @db.Timestamptz
  issuedAt          DateTime          @default(now()) @map("issued_at") @db.Timestamptz
  expiresAt         DateTime?         @map("expires_at") @db.Timestamptz
  verificationUrl   String            @map("verification_url") @db.VarChar(512)
  pdfStorageKey     String?           @map("pdf_storage_key") @db.VarChar(512)
  metadata          Json              @default("{}")
  revokedAt         DateTime?         @map("revoked_at") @db.Timestamptz
  revokedById       String?           @map("revoked_by_id") @db.Uuid
  revokeReason      String?           @map("revoke_reason") @db.Text
  reissuedFromId    String?           @map("reissued_from_id") @db.Uuid
  issuedById        String?           @map("issued_by_id") @db.Uuid
  createdAt         DateTime          @default(now()) @map("created_at") @db.Timestamptz
  updatedAt         DateTime          @updatedAt @map("updated_at") @db.Timestamptz

  organization  Organization            @relation(fields: [organizationId], references: [id])
  enrollment    Enrollment              @relation(fields: [enrollmentId], references: [id])
  course        Course                  @relation(fields: [courseId], references: [id])
  student       User                    @relation("StudentCertificates", fields: [studentId], references: [id])
  template      CertificateTemplate?    @relation(fields: [templateId], references: [id], onDelete: SetNull)
  reissuedFrom  Certificate?            @relation("CertificateReissue", fields: [reissuedFromId], references: [id], onDelete: SetNull)
  reissues      Certificate[]           @relation("CertificateReissue")
  revokedBy     User?                   @relation("RevokedCertificates", fields: [revokedById], references: [id], onDelete: SetNull)
  issuedBy      User?                   @relation("IssuedCertificates", fields: [issuedById], references: [id], onDelete: SetNull)
  verifications CertificateVerification[]

  @@index([studentId, status])
  @@index([courseId, status])
  @@index([enrollmentId])
  @@map("certificates")
}

model CertificateVerification {
  id            String                        @id @default(uuid()) @db.Uuid
  certificateId String?                       @map("certificate_id") @db.Uuid
  credentialId  String                        @map("credential_id") @db.VarChar(100)
  result        CertificateVerificationResult
  ipAddress     String?                       @map("ip_address") @db.VarChar(45)
  userAgent     String?                       @map("user_agent") @db.VarChar(512)
  verifiedAt    DateTime                      @default(now()) @map("verified_at") @db.Timestamptz

  certificate Certificate? @relation(fields: [certificateId], references: [id], onDelete: SetNull)

  @@index([credentialId])
  @@index([certificateId])
  @@map("certificate_verifications")
}

model DemoLead {
  id        String   @id @default(uuid()) @db.Uuid
  name      String   @db.VarChar(255)
  email     String   @db.VarChar(320)
  company   String?  @db.VarChar(255)
  message   String?  @db.Text
  source    String   @default("homepage") @db.VarChar(50)
  createdAt DateTime @default(now()) @map("created_at") @db.Timestamptz

  @@map("demo_leads")
}

// ─── Media & object storage ───────────────────────────────────────────────────

model MediaAsset {
  id             String          @id @default(uuid()) @db.Uuid
  organizationId String          @map("organization_id") @db.Uuid
  ownerId        String          @map("owner_id") @db.Uuid
  assetType      MediaAssetType  @map("asset_type")
  visibility     MediaVisibility @default(private)
  storageKey     String          @map("storage_key") @db.VarChar(512)
  filename       String          @db.VarChar(255)
  mimeType       String          @map("mime_type") @db.VarChar(128)
  sizeBytes      Int             @map("size_bytes")
  width          Int?
  height         Int?
  variants       Json            @default("{}")
  metadata       Json            @default("{}")
  courseId       String?         @map("course_id") @db.Uuid
  batchId        String?         @map("batch_id") @db.Uuid
  lessonId       String?         @map("lesson_id") @db.Uuid
  deletedAt      DateTime?       @map("deleted_at") @db.Timestamptz
  createdAt      DateTime        @default(now()) @map("created_at") @db.Timestamptz
  updatedAt      DateTime        @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization @relation(fields: [organizationId], references: [id])
  owner        User         @relation(fields: [ownerId], references: [id])
  course       Course?      @relation(fields: [courseId], references: [id], onDelete: SetNull)
  batch        Batch?       @relation(fields: [batchId], references: [id], onDelete: SetNull)
  lesson       CourseLesson? @relation(fields: [lessonId], references: [id], onDelete: SetNull)

  @@index([organizationId, assetType])
  @@index([ownerId, createdAt])
  @@index([courseId])
  @@index([batchId])
  @@index([lessonId])
  @@index([deletedAt])
  @@map("media_assets")
}
