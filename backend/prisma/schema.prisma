  question Question @relation(fields: [questionId], references: [id])
  answers  QuizAnswer[]

  @@index([quizId, sortOrder])
  @@map("quiz_questions")
}

model QuizAttempt {
  id                   String            @id @default(uuid()) @db.Uuid
  quizId               String            @map("quiz_id") @db.Uuid
  enrollmentId         String            @map("enrollment_id") @db.Uuid
  attemptNumber        Int               @map("attempt_number")
  score                Float?            @db.DoublePrecision
  maxScore             Float             @map("max_score") @db.DoublePrecision
  percentage           Float?            @db.DoublePrecision
  passed               Boolean?
  status               QuizAttemptStatus @default(in_progress)
  timeTakenSeconds     Int?              @map("time_taken_seconds")
  flaggedQuestionIds   Json              @default("[]") @map("flagged_question_ids")
  answers              Json              @default("{}")
  expiresAt            DateTime?         @map("expires_at") @db.Timestamptz
  startedAt            DateTime          @default(now()) @map("started_at") @db.Timestamptz
  submittedAt          DateTime?         @map("submitted_at") @db.Timestamptz
  lastSavedAt          DateTime?         @map("last_saved_at") @db.Timestamptz

  quiz       Quiz       @relation(fields: [quizId], references: [id])
  enrollment Enrollment @relation(fields: [enrollmentId], references: [id])
  answerRows QuizAnswer[]
  result     QuizResult?

  @@unique([quizId, enrollmentId, attemptNumber])
  @@index([enrollmentId])
  @@index([quizId, status])
  @@map("quiz_attempts")
}

model QuizAnswer {
  id             String                  @id @default(uuid()) @db.Uuid
  attemptId      String                  @map("attempt_id") @db.Uuid
  quizQuestionId String                  @map("quiz_question_id") @db.Uuid
  questionId     String                  @map("question_id") @db.Uuid
