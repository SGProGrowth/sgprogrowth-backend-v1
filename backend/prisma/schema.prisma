  tag      QuestionTag @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([questionId, tagId])
  @@map("question_tag_links")
}

model QuestionAttachment {
  id         String   @id @default(uuid()) @db.Uuid
  questionId String   @map("question_id") @db.Uuid
  storageKey String   @map("storage_key") @db.VarChar(512)
  filename   String   @db.VarChar(255)
  mimeType   String   @map("mime_type") @db.VarChar(128)
  sizeBytes  Int      @map("size_bytes")
  kind       String   @default("file") @db.VarChar(20)
  createdAt  DateTime @default(now()) @map("created_at") @db.Timestamptz

  question Question @relation(fields: [questionId], references: [id], onDelete: Cascade)

  @@index([questionId])
