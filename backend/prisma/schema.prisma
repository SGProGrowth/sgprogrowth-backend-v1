model Question {
  id               String             @id @default(uuid()) @db.Uuid
  organizationId   String             @map("organization_id") @db.Uuid
  instructorId     String             @map("instructor_id") @db.Uuid
  createdById      String             @map("created_by_id") @db.Uuid
  updatedById      String?            @map("updated_by_id") @db.Uuid
  courseId         String?            @map("course_id") @db.Uuid
  moduleId         String?            @map("module_id") @db.Uuid
  lessonId         String?            @map("lesson_id") @db.Uuid
  categoryId       String?            @map("category_id") @db.Uuid
  title            String?            @db.VarChar(500)
  questionText     String             @map("question_text") @db.Text
  explanation      String?            @db.Text
  type             QuestionType
  category         String?            @db.VarChar(100)
  subject          String?            @db.VarChar(150)
  topic            String?            @db.VarChar(150)
  difficulty       QuestionDifficulty @default(medium)
  marks            Int                @default(1) @map("points")
  negativeMarks    Float?             @map("negative_marks")
  estimatedSeconds Int?               @map("estimated_seconds")
  codeSnippet      String?            @map("code_snippet") @db.Text
  tags             String[]           @default([])
  options          Json               @default("{}")
  correctAnswer    Json               @default("{}") @map("correct_answer")
  status           QuestionStatus     @default(active)
  currentVersion   Int                @default(1) @map("current_version")
  createdAt        DateTime           @default(now()) @map("created_at") @db.Timestamptz
  updatedAt        DateTime           @updatedAt @map("updated_at") @db.Timestamptz

  organization Organization       @relation(fields: [organizationId], references: [id])
  instructor   User               @relation(fields: [instructorId], references: [id])
  createdBy    User               @relation("QuestionCreatedBy", fields: [createdById], references: [id])
  updatedBy    User?              @relation("QuestionUpdatedBy", fields: [updatedById], references: [id])
  course       Course?            @relation(fields: [courseId], references: [id], onDelete: SetNull)
  module       CourseModule?      @relation(fields: [moduleId], references: [id], onDelete: SetNull)
  lesson       CourseLesson?      @relation(fields: [lessonId], references: [id], onDelete: SetNull)
  bankCategory QuestionCategory?  @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  optionRows   QuestionOption[]
  tagLinks     QuestionTagLink[]
  attachments  QuestionAttachment[]
  versions     QuestionVersion[]
  quizQuestions QuizQuestion[]
  quizAnswers  QuizAnswer[]

  @@index([organizationId, instructorId, status])
  @@index([instructorId, status])
  @@index([courseId])
  @@index([categoryId])
  @@index([type, difficulty])
  @@map("question_bank_items")
}

model QuestionOption {
  id          String  @id @default(uuid()) @db.Uuid
  questionId  String  @map("question_id") @db.Uuid
